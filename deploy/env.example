# Postgres — dedicated database `sleepguard` on the host instance.
# wow-logs uses localhost:5433 (parser-v2). SleepGuard uses the SAME Postgres
# server, DIFFERENT database and user — never share parser-v2 tables.
#
# Docker compose uses network_mode: host so 127.0.0.1 reaches host Postgres.
DATABASE_URL=postgres://sleepguard:xxxxxxxxxxxxxxxx@127.0.0.1:5433/sleepguard?sslmode=disable

# Read-only key for PWA / curl testing (phase B). Generate: openssl rand -hex 32
SLEEPGUARD_READ_API_KEY=xxxxxxxxxxxxxxxxxx

# Optional: create nursery device on first startup (save token securely).
SLEEPGUARD_BOOTSTRAP_DEVICE_ID=xxxxxxxxxxxxxxxxx
SLEEPGUARD_BOOTSTRAP_DEVICE_NAME=xxxxxxxxxxxxxxxxxx Pi
SLEEPGUARD_BOOTSTRAP_DEVICE_TOKEN=xxxxxxxxxxxxxxxxx

SLEEPGUARD_DEBUG=false

# Retention and cleanup (events + snapshot files on disk)
SLEEPGUARD_EVENT_RETENTION=24h
SLEEPGUARD_CLEANUP_INTERVAL=24h

# Web Push (Phase D). Generate on any machine with Node:
#   npx web-push generate-vapid-keys
# Or with Go (one-liner): go run ./scripts/gen-vapid-keys.go
SLEEPGUARD_VAPID_PUBLIC_KEY=
SLEEPGUARD_VAPID_PRIVATE_KEY=
SLEEPGUARD_VAPID_SUBJECT=mailto:sleepguard@rksdevs.in

# Pattern rules (Phase E) — rise→fall = 1 cycle; push every 3 cycles
SLEEPGUARD_RULE_NOTIFY_CYCLES=3
SLEEPGUARD_RULE_IDLE_RESET=10m
