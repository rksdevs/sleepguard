# Pi agent config — copy to deploy/agent.env (not committed).
# Device token = SLEEPGUARD_BOOTSTRAP_DEVICE_TOKEN from Hetzner deploy/.env

SLEEPGUARD_CLOUD_URL=https://sleepguard.rksdevs.in
SLEEPGUARD_DEVICE_TOKEN=CHANGE_ME
SLEEPGUARD_DEVICE=nursery
SLEEPGUARD_DEBUG=false

# How often the Pi checks for a capture request from the PWA (default 5s).
# SLEEPGUARD_COMMAND_POLL_INTERVAL=5s
